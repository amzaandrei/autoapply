# Copy this file to .env.production on the VPS and fill in real values.
# DO NOT COMMIT the filled-in .env.production file.

# ─── Domain & base URLs ────────────────────────────────────────────────────
DOMAIN=example.com
NEXT_PUBLIC_APP_URL=https://example.com
NEXTAUTH_URL=https://example.com

# Optional co-tenant: if you also deploy /opt/portofolio on this VPS, set the
# portfolio's hostname here so this stack's Caddy serves it on the shared
# `web` Docker network. Leave empty if you only run autoapply.
DOMAIN_PORTFOLIO=

# Optional co-tenant: if you also deploy /opt/slideprep on this VPS, set the
# slideprep hostname here. Caddy will proxy it to slideprep-app-1:3003 on the
# shared `web` network. Leave empty if slideprep isn't deployed here.
DOMAIN_SLIDEPREP=

# ─── Secrets (generate with `openssl rand -base64 32`) ─────────────────────
AUTH_SECRET=
DB_PASSWORD=
REDIS_PASSWORD=

# NextAuth v5 rejects requests whose Host header it doesn't recognize unless
# told the server is behind a trusted reverse proxy. Caddy is that proxy, so
# this must be true in any containerized deploy.
AUTH_TRUST_HOST=true

# ─── OAuth / Gmail ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://example.com/api/gmail/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── AI / external APIs ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RAPIDAPI_KEY=
HUNTER_API_KEY=

# ─── Mapbox (client-side, also exposed in build args) ──────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_TOKEN=

# ─── Stripe (production live keys) ─────────────────────────────────────────
# Price IDs come from your Stripe dashboard → Products. Create one recurring
# price per plan (STARTER, PRO, POWER) and paste the `price_...` IDs here.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_POWER=

# ─── Stripe (optional: still keep test keys for local compose test-mode) ──
# STRIPE_SECRET_KEY_TEST=
# STRIPE_WEBHOOK_SECRET_TEST=
# STRIPE_PRICE_ID_STARTER_TEST=
# STRIPE_PRICE_ID_PRO_TEST=
# STRIPE_PRICE_ID_POWER_TEST=

# ─── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# ─── Notifications (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Cost guards ───────────────────────────────────────────────────────────
ANTHROPIC_DAILY_USD_CAP=50
HUNTER_DAILY_USD_CAP=5
RAPIDAPI_DAILY_USD_CAP=10

# ─── Worker ────────────────────────────────────────────────────────────────
WORKER_CRON_ENABLED=true
# Set to "true" to let the worker run templates on autopilot (hourly sweep,
# per-template frequency controlled by the user). Leave false until you're
# confident the user-facing controls are wired up in your deployment.
AUTOPILOT_ENABLED=false

# ─── Admin access ─────────────────────────────────────────────────────────
# Comma-separated list of emails that can access /admin. Start with your own.
ADMIN_EMAILS=

# ─── LangSmith tracing (optional) ─────────────────────────────────────────
# Set LANGSMITH_TRACING=true and provide LANGSMITH_API_KEY to capture every
# Anthropic call (prompt, response, usage, latency) for inspection at
# smith.langchain.com. Leave LANGSMITH_TRACING unset (or "false") to disable
# — wrapAnthropic short-circuits with no runtime overhead.
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=autoapply

# ─── Build metadata (filled by CI/deploy script) ──────────────────────────
GIT_SHA=
