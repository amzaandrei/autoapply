# Copy this file to .env.production on the VPS and fill in real values.
# DO NOT COMMIT the filled-in .env.production file.

# ─── Domain & base URLs ────────────────────────────────────────────────────
DOMAIN=example.com
NEXT_PUBLIC_APP_URL=https://example.com
NEXTAUTH_URL=https://example.com

# ─── Secrets (generate with `openssl rand -base64 32`) ─────────────────────
AUTH_SECRET=
DB_PASSWORD=
REDIS_PASSWORD=

# ─── OAuth / Gmail ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=https://example.com/api/gmail/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ─── AI / external APIs ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
RAPIDAPI_KEY=
HUNTER_API_KEY=

# ─── Mapbox (client-side, also exposed in build args) ──────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=
MAPBOX_TOKEN=

# ─── Stripe (production live keys) ─────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=

# ─── Stripe (optional: still keep test keys for local compose test-mode) ──
# STRIPE_SECRET_KEY_TEST=
# STRIPE_WEBHOOK_SECRET_TEST=
# STRIPE_PRICE_ID_PRO_TEST=

# ─── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com

# ─── Notifications (optional) ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Cost guards ───────────────────────────────────────────────────────────
ANTHROPIC_DAILY_USD_CAP=50
HUNTER_DAILY_USD_CAP=5
RAPIDAPI_DAILY_USD_CAP=10

# ─── Worker ────────────────────────────────────────────────────────────────
WORKER_CRON_ENABLED=true

# ─── Build metadata (filled by CI/deploy script) ──────────────────────────
GIT_SHA=
