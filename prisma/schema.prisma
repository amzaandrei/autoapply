generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

// ─── Auth Models ────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  profile      UserProfile?
  campaigns    Campaign[]
  gmailToken   GmailToken?
  blacklist    BlacklistedCompany[]
  templates    CampaignTemplate[]
  subscription Subscription?
}

// ─── Billing ────────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  POWER
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier                 SubscriptionTier   @default(FREE)
  status               SubscriptionStatus @default(ACTIVE)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model UsageCounter {
  id        String   @id @default(cuid())
  userId    String
  action    String   // "email_sent" | "ai_generation" | "discovery" | "follow_up" | "hunter_request"
  period    String   // "YYYY-MM" or "YYYY-MM-DD-HH" for hourly actions
  count     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, action, period])
  @@index([userId, period])
}

model StripeEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── AutoApply Models ───────────────────────────────────────────────────────

model UserProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  cvUrl             String?
  cvText            String?  @db.Text
  cvPdfBase64       String?  @db.Text
  jobTitle          String?
  skills            String[] @default([])
  bio               String?  @db.Text
  linkedIn          String?
  portfolio         String?
  emailTemplate     String?  @db.Text
  useEmailTemplate  Boolean  @default(false)
  signatureName     String?
  signaturePhone    String?
  signatureAddress  String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id                String         @id @default(cuid())
  userId            String
  name              String
  description       String?        @db.Text
  status            CampaignStatus @default(DRAFT)
  jobTitle          String?
  industry          String?
  region            String?
  useEmailTemplate  Boolean        @default(false)
  followUpEnabled   Boolean        @default(false)
  followUpDelayDays Int            @default(5)
  maxFollowUps      Int            @default(1)
  abTestEnabled     Boolean        @default(false)
  abToneA           String         @default("concise")
  abToneB           String         @default("detailed")
  attachCv          Boolean        @default(true)
  targetCount       Int            @default(0)
  sentCount         Int            @default(0)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  companies Company[]
  emails    GeneratedEmail[]
}

model Company {
  id           String        @id @default(cuid())
  campaignId   String
  name         String
  domain       String?
  industry     String?
  size         String?
  description  String?       @db.Text
  contactEmail String?
  contactName  String?
  linkedIn     String?
  latitude     Float?
  longitude    Float?
  region       String?
  status       CompanyStatus @default(PENDING)
  notes        String?       @db.Text
  // Deliverability verification (Hunter.io + DNS fallback). Stale after ~30d.
  contactEmailStatus   String?  // 'valid' | 'accept_all' | 'webmail' | 'invalid' | 'disposable' | 'unknown' | 'error'
  contactEmailScore    Int?     // 0-100 Hunter score; null if not checked
  contactEmailVerifiedAt DateTime?
  // Hunter Company Enrichment — firmographics. Populated on discovery for
  // paid tiers. Null fields mean the field wasn't in Hunter's dataset.
  yearFounded   Int?
  country       String?
  locality      String?
  logo          String?
  techStack     String[]      @default([])
  enrichedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([latitude, longitude])

  campaign        Campaign         @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  emails          GeneratedEmail[]
  interviewStages InterviewStage[]
}

model GeneratedEmail {
  id              String      @id @default(cuid())
  companyId       String
  campaignId      String
  subject         String
  body            String      @db.Text
  status          EmailStatus @default(DRAFT)
  sentAt          DateTime?
  gmailThreadId   String?
  gmailMessageId  String?
  openedAt        DateTime?
  openCount       Int         @default(0)
  repliedAt       DateTime?
  variant         String?
  abGroup         String?
  notes           String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  campaign  Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  followUps FollowUp[]
}

model FollowUp {
  id             String         @id @default(cuid())
  emailId        String
  sequence       Int
  scheduledAt    DateTime
  sentAt         DateTime?
  gmailMessageId String?
  subject        String
  body           String         @db.Text
  status         FollowUpStatus @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  email GeneratedEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
}

model GmailToken {
  id           String    @id @default(cuid())
  userId       String    @unique
  accessToken  String    @db.Text
  refreshToken String?   @db.Text
  expiresAt    DateTime?
  scope        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CampaignTemplate {
  id                String   @id @default(cuid())
  userId            String
  name              String
  selectedRoles     String[] @default([])
  jobTitle          String?
  industry          String?
  region            String?
  searchMode        String   @default("top10")
  dataSource        String   @default("both")
  useEmailTemplate  Boolean  @default(false)
  attachCv          Boolean  @default(true)
  followUpEnabled   Boolean  @default(false)
  followUpDelayDays Int      @default(5)
  maxFollowUps      Int      @default(1)
  abTestEnabled     Boolean  @default(false)
  abToneA           String   @default("concise")
  abToneB           String   @default("detailed")

  // Autopilot — cron-driven autonomous discovery + generation + send
  autopilotEnabled         Boolean   @default(false)
  autopilotFrequency       String    @default("daily") // "daily" | "every2days" | "weekly"
  autopilotDailyCap        Int       @default(5)       // max new companies per run
  autopilotRequireApproval Boolean   @default(true)    // true → save as READY drafts; false → auto-send
  autopilotTone            String    @default("balanced")
  autopilotAcceptedAt      DateTime?                    // consent timestamp — null means never opted in
  autopilotLastRunAt       DateTime?
  autopilotNextRunAt       DateTime?
  autopilotCampaignId      String?                      // linked long-running campaign

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs AutopilotRun[]

  @@index([autopilotEnabled, autopilotNextRunAt])
}

model AutopilotRun {
  id          String    @id @default(cuid())
  templateId  String
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  status      String    @default("RUNNING") // RUNNING | SUCCESS | FAILED | SKIPPED
  skipReason  String?   // e.g. "quota", "no_cv", "no_gmail", "not_pro"
  discovered  Int       @default(0)
  generated   Int       @default(0)
  sent        Int       @default(0)
  failed      Int       @default(0)
  error       String?   @db.Text
  createdAt   DateTime  @default(now())

  template CampaignTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, startedAt])
}

model InterviewStage {
  id          String   @id @default(cuid())
  companyId   String
  stage       String   // APPLIED, PHONE_SCREEN, TECHNICAL, ONSITE, OFFER, REJECTED, ACCEPTED
  scheduledAt DateTime?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model BlacklistedCompany {
  id        String   @id @default(cuid())
  userId    String
  name      String
  domain    String?
  reason    String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

// ─── Enums ──────────────────────────────────────────────────────────────────

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum CompanyStatus {
  PENDING
  APPROVED
  REJECTED
  EMAILED
  REPLIED
  ARCHIVED
}

enum EmailStatus {
  DRAFT
  READY
  SENT
  OPENED
  REPLIED
  BOUNCED
  ARCHIVED
}

enum FollowUpStatus {
  PENDING
  SENT
  CANCELLED
}
